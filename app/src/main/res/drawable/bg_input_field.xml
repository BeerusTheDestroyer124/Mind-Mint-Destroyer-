<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused State -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/surface_nested" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/brand_pink" />
        </shape>
    </item>
    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/surface_nested" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="?attr/glass_stroke" />
        </shape>
    </item>
</selector>