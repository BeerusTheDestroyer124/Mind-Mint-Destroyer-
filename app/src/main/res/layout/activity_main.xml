<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/app_bg"
    tools:context=".Activities.HomeActivity"
    tools:ignore="ContentDescription">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/nav_host_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@+id/nav_bar_container"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Lock In floating pill -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/lockInPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_brand_gradient"
        android:backgroundTint="@null"
        android:elevation="12dp"
        android:fontFamily="@font/poppins_semibold"
        android:letterSpacing="0.05"
        android:minWidth="0dp"
        android:paddingHorizontal="18dp"
        android:text="Lock In"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:backgroundTint="@null"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@+id/nav_bar_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:rippleColor="#40FFFFFF" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/nav_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="45dp"
        android:elevation="20dp"
        android:layout_marginEnd="45dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/nav_background"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_nav_pill"
            android:elevation="0dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="5"
            app:layout_constraintBottom_toBottomOf="parent">

            <FrameLayout
                android:id="@+id/nav_unlink"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:background="@drawable/selector_nav_item"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/quitIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/quit"
                    app:tint="@color/icon_unselected" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_task"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/selector_nav_item"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/taskIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/list_todo"
                    app:tint="@color/icon_unselected" />

            </FrameLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <FrameLayout
                android:id="@+id/nav_habits"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/selector_nav_item"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/habitIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/flame"
                    app:tint="@color/icon_unselected" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_setting"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:background="@drawable/selector_nav_item"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/settingsIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/settings"
                    app:tint="@color/icon_unselected" />

            </FrameLayout>

        </LinearLayout>

        <View
            android:id="@+id/home_glow_effect"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:alpha="0.6"
            android:background="@drawable/bg_home_circle"
            android:clickable="false"
            android:focusable="false"
            android:scaleX="1.2"
            android:scaleY="1.2"
            app:layout_constraintBottom_toBottomOf="@+id/btn_home"
            app:layout_constraintEnd_toEndOf="@+id/btn_home"
            app:layout_constraintStart_toStartOf="@+id/btn_home"
            app:layout_constraintTop_toTopOf="@+id/btn_home" />

        <ImageButton
            android:id="@+id/btn_home"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_home_circle"
            android:contentDescription="@string/home"
            android:elevation="10dp"
            android:src="@drawable/home"
            app:layout_constraintBottom_toBottomOf="@+id/nav_background"
            app:layout_constraintEnd_toEndOf="@+id/nav_background"
            app:layout_constraintStart_toStartOf="@+id/nav_background"
            app:layout_constraintTop_toTopOf="@+id/nav_background"
            app:tint="#FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
















