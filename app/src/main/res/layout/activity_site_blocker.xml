<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/app_bg"
    tools:context=".Activities.SiteBlockerActivity"
    tools:ignore="ContentDescription,HardcodedText,Autofill,TextFields">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="30dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@+id/infoBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/dateDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:fontFamily="@font/poppins_semibold"
            android:letterSpacing="0.1"
            android:text="Firewall for domains"
            android:textAllCaps="true"
            android:textColor="?attr/text_tertiary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/greetings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="0.8"
            android:text="Site blocker"
            android:textColor="?attr/text_primary"
            android:textSize="30sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/welcomeTxt" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/infoBtn"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/glass_circle"
        app:backgroundTint="@null"
        app:icon="@drawable/info"
        app:iconGravity="textStart"
        app:iconTint="?attr/text_primary"
        app:layout_constraintBottom_toBottomOf="@+id/headerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerContainer" />

    <LinearLayout
        android:id="@+id/inputConsole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_firewall_input"
                android:hint="Enter URL to block..."
                android:inputType="textUri"
                android:paddingStart="56dp"
                android:paddingEnd="100dp"
                android:textColor="?attr/text_primary"
                android:textColorHint="?attr/text_tertiary"
                android:textSize="14sp" />

            <!-- Link Icon -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="20dp"
                android:src="@drawable/link"
                app:tint="?attr/text_tertiary" />

            <!-- Block Button (Inside Input) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBlock"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_brand_gradient"
                android:paddingHorizontal="16dp"
                android:text="BLOCK"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Tab Selector -->
        <LinearLayout
            android:id="@+id/tabContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_segment_container"
            android:gravity="center_vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/tabDomain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_segment_selected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Block whole domain"
                android:textColor="?attr/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabExactUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Block exact URL"
                android:textColor="?attr/text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_blocked_sites"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inputConsole"
        tools:listitem="@layout/item_blocked_site" />

    <LinearLayout
        android:id="@+id/noteWarn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/rounded_bg"
        android:gravity="center_vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="?attr/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Site are blocked across all Chromium based browsers and Firefox. \nEdge and Samsung Browser only support full domain block."
            android:textColor="?attr/text_secondary"
            android:textSize="11sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


