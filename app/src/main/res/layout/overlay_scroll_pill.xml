<?xml version="1.0" encoding="utf-8"?>
<!-- Fully transparent host, only the pill is visible. FLAG_NOT_TOUCHABLE means all touches pass through to the app. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:gravity="top|center_horizontal"
    android:paddingTop="52dp">

    <LinearLayout
        android:id="@+id/pillContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:alpha="0.0"
        android:background="@drawable/pill_bg"
        android:backgroundTint="#55000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/pillAppIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/scroll_text"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/pillScrollCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            tools:text="247 scrolls" />

    </LinearLayout>

</FrameLayout>
