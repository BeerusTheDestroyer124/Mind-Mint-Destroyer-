<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/surface_card"
    android:padding="20dp">

    <View
        android:id="@+id/dragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="8dp"
        android:background="#4D8E8E93"
        android:backgroundTint="?attr/glass_stroke"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/sheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/set_your_focus_time"
        android:textColor="?attr/text_primary"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dragHandle" />

    <!-- Normal Timer Display -->
    <TextView
        android:id="@+id/normalTimerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-light"
        android:text="10 min"
        android:textColor="?attr/text_secondary"
        android:textSize="32sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/sheetTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/sheetTitle" />

    <!-- Configuration Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/configCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="?attr/surface_nested"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@+id/sheetTitle"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Normal Duration Section -->
            <LinearLayout
                android:id="@+id/normalDurationSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Duration"
                    android:textColor="?attr/text_secondary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/durationSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="170"
                    android:progress="0"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progressTint="?attr/tintGlobalColor"
                    android:thumbTint="?attr/tintGlobalColor" />
            </LinearLayout>

            <!-- Pomodoro Section -->
            <LinearLayout
                android:id="@+id/pomodoroSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Focus Duration -->
                <TextView
                    android:id="@+id/focusDurationLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Focus Interval: 25 min"
                    android:textColor="?attr/text_secondary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/focusSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="25"
                    android:progress="5"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progressTint="?attr/tintGlobalColor"
                    android:thumbTint="?attr/tintGlobalColor" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/glass_stroke" />

                <!-- Auto Resume Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Auto Resume"
                        android:textColor="?attr/text_secondary"
                        android:textSize="14sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/autoResumeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="?attr/switchThumb"
                        app:trackTint="?attr/switchTrack" />

                </LinearLayout>

                <!-- Break Settings Container (Conditional Visibility) -->
                <LinearLayout
                    android:id="@+id/breakSettingsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/breakDurationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Break Duration: 5 min"
                        android:textColor="?attr/text_secondary"
                        android:textSize="14sp" />

                    <SeekBar
                        android:id="@+id/breakSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:max="12"
                        android:progress="2"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progressTint="?attr/tintGlobalColor"
                        android:thumbTint="?attr/tintGlobalColor" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Topics Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topicsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="?attr/surface_nested"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@+id/configCard"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Select Tag (Optional)"
                android:textColor="?attr/text_secondary"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/topicsChipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true" />

            </HorizontalScrollView>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Save For Next Time -->
    <LinearLayout
        android:id="@+id/saveOptionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/topicsCard">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="Save for next time"
            android:textColor="?attr/text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/saveForNextSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbTint="?attr/switchThumb"
            app:trackTint="?attr/switchTrack" />

    </LinearLayout>

    <Button
        android:id="@+id/startBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/brainColor"
        android:fontFamily="sans-serif-medium"
        android:text="@string/start"
        android:textColor="@color/white"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@+id/saveOptionContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>
