<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/app_bg"
    android:orientation="vertical"
    tools:ignore="HardcodedText">

    <!-- 1. Main Header (Fixed, Outside Coordinator) -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/app_bg"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="30dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dateDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:alpha="0.5"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.1"
                android:text="Your daily rhythm"
                android:textAllCaps="true"
                android:textColor="?attr/text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/greetings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="0.8"
                android:text="Life Intel"
                android:textColor="?attr/text_primary"
                android:textSize="30sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/viewChanger"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_segment_container"
            android:padding="4dp">

            <TextView
                android:id="@+id/btnWeekly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_segment_selected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="WEEKLY"
                android:textColor="?attr/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnMonthly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="MONTHLY"
                android:textColor="?attr/text_tertiary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- 2. Content Area (CoordinatorLayout) -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/app_bg"
            android:stateListAnimator="@null"
            app:elevation="0dp">

            <!-- Scrollable Middle Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                app:layout_scrollFlags="scroll|snap">

                <!-- Scroll Count Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/brainHolderX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="?attr/surface_card"
                    app:cardCornerRadius="30dp"
                    app:strokeColor="?attr/glass_stroke"
                    app:strokeWidth="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/scrollLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.6"
                            android:letterSpacing="0.1"
                            android:text="Today's scroll count"
                            android:textColor="?attr/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.gxdevs.mindmint.Views.CustomPieChart
                            android:id="@+id/pieChartX"
                            android:layout_width="180dp"
                            android:layout_height="170dp"
                            android:layout_marginTop="5dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/scrollLabel"
                            app:pieGlow="12dp"
                            app:pieRadius="65dp"
                            app:pieTextSize="11dp"
                            app:pieThickness="20dp" />

                        <ImageView
                            android:id="@+id/brainImage"
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:contentDescription="@string/app_name"
                            android:src="@drawable/brain1"
                            android:transitionName="brainTransition"
                            app:layout_constraintBottom_toBottomOf="@id/pieChartX"
                            app:layout_constraintEnd_toEndOf="@id/pieChartX"
                            app:layout_constraintStart_toStartOf="@id/pieChartX"
                            app:layout_constraintTop_toTopOf="@+id/pieChartX" />

                        <TextView
                            android:id="@+id/tvTotalScrolls"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="--"
                            android:textColor="?attr/text_primary"
                            android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/pieChartX" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:baselineAligned="false"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tvTotalScrolls">

                            <include
                                android:id="@+id/statInsta"
                                layout="@layout/item_stat_row_compact"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="5dp"
                                android:layout_weight="1" />

                            <include
                                android:id="@+id/statYoutube"
                                layout="@layout/item_stat_row_compact"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="5dp"
                                android:layout_weight="1" />

                            <include
                                android:id="@+id/statSnap"
                                layout="@layout/item_stat_row_compact"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Permission Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/permissionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_surface_glass"
                    android:backgroundTint="?attr/status_error_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="16dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/frameAlertIcon"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:background="@drawable/glass_circle"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/status_error_icon" />

                    <TextView
                        android:id="@+id/tvAlertTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="8dp"
                        android:text="Permission Required"
                        android:textColor="?attr/status_error_icon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow1"
                        app:layout_constraintStart_toEndOf="@id/frameAlertIcon"
                        app:layout_constraintTop_toTopOf="@id/frameAlertIcon" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Accessibility permission is required for scroll count, blocking and other stats."
                        android:textColor="?attr/status_error_text"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="@id/tvAlertTitle"
                        app:layout_constraintStart_toStartOf="@id/tvAlertTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvAlertTitle" />

                    <ImageView
                        android:id="@+id/ivArrow1"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_right_arrow"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/status_error_icon" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Period Selector -->
                <LinearLayout
                    android:id="@+id/calendarHolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/arrowLeft"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Back"
                        android:rotation="180"
                        android:src="@drawable/ic_right_arrow"
                        app:tint="?attr/text_tertiary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/surface_card"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/brand_pink" />

                        <TextView
                            android:id="@+id/periodLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Week 49, 2025"
                            android:textColor="?attr/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/arrowRight"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Forward"
                        android:src="@drawable/ic_right_arrow"
                        app:tint="?attr/text_tertiary" />

                </LinearLayout>

            </LinearLayout>

            <!-- 3. Tabs (Sticky) -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/bg_segment_container"
                app:tabBackground="@drawable/selector_tab_transparent"
                app:tabIndicator="@drawable/bg_segment_selected"
                app:tabIndicatorColor="@null"
                app:tabIndicatorFullWidth="true"
                app:tabIndicatorGravity="stretch"
                app:tabMode="fixed"
                app:tabRippleColor="@null"
                app:tabSelectedTextColor="?attr/text_primary"
                app:tabTextColor="?attr/text_tertiary" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</LinearLayout>
