<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/transparent"
    tools:ignore="ContentDescription,HardcodedText,Autofill,TextFields">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="30dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@id/addTasksBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/dateDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginTop="15dp"
            android:letterSpacing="0.1"
            android:text="4 REMAINING"
            android:textAllCaps="true"
            android:textColor="?attr/text_tertiary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/greetings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="0.8"
            android:text="Daily Quests"
            android:textColor="?attr/text_primary"
            android:textSize="30sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/welcomeTxt" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addTasksBtn"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/glass_circle"
        app:backgroundTint="@null"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"
        app:iconTint="?attr/text_primary"
        app:layout_constraintBottom_toBottomOf="@+id/headerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerContainer" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="?attr/surface_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerContainer"
        app:strokeColor="?attr/embeddedCards"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Search Icon -->
            <ImageView
                android:id="@+id/searchIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:layout_constraintBottom_toBottomOf="@+id/searchEditText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/searchEditText"
                app:tint="?attr/tintGlobalColor" />

            <!-- Search EditText -->
            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:background="@android:color/transparent"
                android:fontFamily="@font/inter18regular"
                android:hint="Search tasks..."
                android:textColor="?attr/tintGlobalColor"
                android:textColorHint="?attr/tintGlobalColor"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/filterButton"
                app:layout_constraintStart_toEndOf="@+id/searchIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Filter Button -->
            <ImageView
                android:id="@+id/filterButton"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_filter"
                app:layout_constraintBottom_toBottomOf="@+id/searchEditText"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/searchEditText"
                app:tint="@color/brainColor" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <HorizontalScrollView
        android:id="@+id/filterScrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchCard">

        <LinearLayout
            android:id="@+id/filterChipContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:spacing="8dp" />

    </HorizontalScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/permissionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_surface_glass"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filterScrollView"> <!-- Ripple Effect -->

        <ImageView
            android:id="@+id/frameAlertIcon"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:background="@drawable/glass_circle"
            android:padding="8dp"
            android:src="@drawable/alarm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/status_warning_icon" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvAlertTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Permission Required"
            android:textColor="?attr/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/ivArrow1"
            app:layout_constraintStart_toEndOf="@id/frameAlertIcon"
            app:layout_constraintTop_toTopOf="@id/frameAlertIcon" />

        <!-- Description -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/accurate"
            android:textColor="?attr/text_tertiary"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@id/tvAlertTitle"
            app:layout_constraintStart_toStartOf="@id/tvAlertTitle"
            app:layout_constraintTop_toBottomOf="@id/tvAlertTitle" />

        <!-- Arrow Icon -->
        <ImageView
            android:id="@+id/ivArrow1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_right_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/text_tertiary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/notiPermissionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_surface_glass"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/permissionCard"> <!-- Ripple Effect -->

        <ImageView
            android:id="@+id/frameNotiAlertIcon"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:background="@drawable/glass_circle"
            android:padding="8dp"
            android:src="@drawable/bell"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/status_info_icon" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvNotiAlertTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Permission Required"
            android:textColor="?attr/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/ivNotiArrow1"
            app:layout_constraintStart_toEndOf="@id/frameNotiAlertIcon"
            app:layout_constraintTop_toTopOf="@id/frameNotiAlertIcon" />

        <!-- Description -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp"
            android:text="Provide notification permission to show notifications on time"
            android:textColor="?attr/text_tertiary"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@id/tvNotiAlertTitle"
            app:layout_constraintStart_toStartOf="@id/tvNotiAlertTitle"
            app:layout_constraintTop_toBottomOf="@id/tvNotiAlertTitle" />

        <!-- Arrow Icon -->
        <ImageView
            android:id="@+id/ivNotiArrow1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_right_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/text_tertiary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Current Focus Label -->
    <TextView
        android:id="@+id/currentFocusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/poppins_semibold"
        android:text="CURRENT FOCUS"
        android:textColor="?attr/brand_pink"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/notiPermissionCard" />

    <!-- Three dots menu (optional) -->
    <ImageView
        android:id="@+id/currentFocusMenu"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="20dp"
        android:contentDescription="Menu"
        android:src="@drawable/ic_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/currentFocusLabel"
        app:tint="?attr/tintGlobalColor" />

    <!-- Current Focus Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/currentFocusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="?attr/surface_card"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@+id/currentFocusLabel">

        <com.apachat.swipereveallayout.core.SwipeLayout
            android:id="@+id/swipeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:dragEdge="top">

            <LinearLayout
                android:id="@+id/swipeActionsLayout"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="50dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Edit Button -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/editButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#4CAF50">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_edit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white"
                        tools:ignore="ContentDescription" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Delete Button -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/deleteButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#F44336">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/trash"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white"
                        tools:ignore="ContentDescription" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/currentFocusInner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/surface_card"
                android:clickable="true"
                android:focusable="true"
                android:padding="20dp">

                <TextView
                    android:id="@+id/currentFocusPriorityLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/importance_bg"
                    android:fontFamily="sans-serif"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="High Priority"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/currentFocusTaskName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="130dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Finalize Design System"
                    android:textColor="?attr/text_primary"
                    android:textSize="24sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/currentFocusPriorityLabel" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/currentFocusDueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:drawableStart="@drawable/clock"
                    android:drawablePadding="5dp"
                    android:drawableTint="?attr/text_tertiary"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:text="Due 5 PM"
                    android:textColor="?attr/text_tertiary"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/currentFocusTaskName" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/currentFocusMarkButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/circular_rectangle"
                    android:backgroundTint="?attr/text_primary"
                    android:padding="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/currentFocusDueDate">

                    <TextView
                        android:id="@+id/currentFocusMarkButtonText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:gravity="center"
                        android:text="Mark Completed"
                        android:textColor="?attr/surface_card"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/circular_rectangle_img"
                        android:backgroundTint="?attr/surface_card"
                        android:padding="6dp"
                        android:src="@drawable/ic_tick"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearance="@style/roundImageView"
                        app:tint="?attr/text_primary" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.apachat.swipereveallayout.core.SwipeLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/upNextLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:alpha="0.7"
        android:text="UP NEXT"
        android:textColor="?attr/tintGlobalColor"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/currentFocusCard" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tasksRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="10dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/upNextLabel"
        tools:listitem="@layout/item_task" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filterScrollView">

        <ImageView
            android:id="@+id/emptyStateImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:alpha="0.6"
            android:src="@drawable/scroll_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/emptyStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:alpha="0.7"
            android:fontFamily="@font/poppins_semibold"
            android:text="No tasks found"
            android:textAlignment="center"
            android:textColor="@color/textColor"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/emptyStateImage" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:alpha="0.5"
            android:fontFamily="@font/inter18regular"
            android:text="Tap the + button to add a new task"
            android:textAlignment="center"
            android:textColor="@color/textColor"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/emptyStateText" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
