<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/surface_card"
    android:elevation="20dp"
    tools:ignore="HardcodedText, ContentDescription">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/settingsHolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="25dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@+id/crossBtn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/dateDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.5"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.1"
                android:text="Focus Preference"
                android:textAllCaps="true"
                android:textColor="?attr/text_tertiary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="0.8"
                android:text="Focus Settings"
                android:textColor="?attr/text_primary"
                android:textSize="35sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/crossBtn"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/glass_circle"
            android:padding="10dp"
            android:src="@drawable/x"
            app:layout_constraintBottom_toBottomOf="@+id/headerContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/headerContainer"
            app:tint="?attr/text_secondary" />

        <!-- Theme Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/themeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:elevation="4dp"
            app:cardBackgroundColor="?attr/surface_nested"
            app:cardCornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@+id/headerContainer"
            app:strokeColor="@color/glass_stroke"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/themeLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:padding="10dp"
                    android:src="@drawable/moon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Dark Mode"
                    android:textColor="?attr/text_primary"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@+id/themeLogo"
                    app:layout_constraintStart_toEndOf="@+id/themeLogo"
                    app:layout_constraintTop_toTopOf="@+id/themeLogo" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/themeSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/themeLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/themeLogo"
                    app:thumbTint="?attr/switchThumb"
                    app:trackTint="?attr/switchTrack" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Pomodoro Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pomoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:elevation="4dp"
            app:cardBackgroundColor="?attr/surface_nested"
            app:cardCornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@+id/themeCard"
            app:strokeColor="@color/glass_stroke"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/pomoLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:padding="10dp"
                    android:src="@drawable/clock"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Pomodoro Timer"
                    android:textColor="?attr/text_primary"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@+id/pomoLogo"
                    app:layout_constraintStart_toEndOf="@+id/pomoLogo"
                    app:layout_constraintTop_toTopOf="@+id/pomoLogo" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/pomodoroSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/pomoLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/pomoLogo"
                    app:thumbTint="?attr/switchThumb"
                    app:trackTint="?attr/switchTrack" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/pomodoroSettings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/pomoLogo">

                    <View
                        android:id="@+id/border1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/glass_stroke"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/focusDurationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Focus Interval: 30 min"
                        android:textColor="?attr/text_secondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/border1" />

                    <SeekBar
                        android:id="@+id/focusSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="25"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progress="10"
                        android:progressTint="?attr/tintGlobalColor"
                        android:thumbTint="?attr/tintGlobalColor"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/focusDurationLabel" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Break Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/breakCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:elevation="4dp"
            app:cardBackgroundColor="?attr/surface_nested"
            app:cardCornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@+id/pomoCard"
            app:strokeColor="@color/glass_stroke"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/breakLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:padding="10dp"
                    android:src="@drawable/hourglass"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Auto Resume"
                    android:textColor="?attr/text_primary"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@+id/breakLogo"
                    app:layout_constraintStart_toEndOf="@+id/breakLogo"
                    app:layout_constraintTop_toTopOf="@+id/breakLogo" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/breakSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/breakLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/breakLogo"
                    app:thumbTint="?attr/switchThumb"
                    app:trackTint="?attr/switchTrack" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/breakSettings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/breakLogo">

                    <View
                        android:id="@+id/border2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/glass_stroke"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/breakDurationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Break Duration: 5 min"
                        android:textColor="?attr/text_secondary"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/border2" />

                    <SeekBar
                        android:id="@+id/breakSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="12"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progress="2"
                        android:progressTint="?attr/tintGlobalColor"
                        android:thumbTint="?attr/tintGlobalColor"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/breakDurationLabel" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            app:layout_constraintTop_toBottomOf="@+id/breakCard" />

        <!-- Scheduled Focus Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/scheduleCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:elevation="4dp"
            app:cardBackgroundColor="?attr/surface_nested"
            app:cardCornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@+id/breakCard"
            app:strokeColor="@color/glass_stroke"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/scheduleLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:padding="10dp"
                    android:src="@drawable/clock"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Scheduled Focus"
                    android:textColor="?attr/text_primary"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@+id/scheduleLogo"
                    app:layout_constraintStart_toEndOf="@+id/scheduleLogo"
                    app:layout_constraintTop_toTopOf="@+id/scheduleLogo" />

                <ImageView
                    android:id="@+id/addScheduleBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:padding="8dp"
                    android:src="@drawable/ic_add"
                    app:layout_constraintBottom_toBottomOf="@+id/scheduleLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/scheduleLogo"
                    app:tint="?attr/text_primary" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/schedulesContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/scheduleLogo">

                    <View
                        android:id="@+id/border3"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/glass_stroke"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/scheduleRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@+id/border3" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            app:layout_constraintTop_toBottomOf="@+id/scheduleCard" />

        <!-- Always Lock In Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/alwaysLockInCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:elevation="4dp"
            app:cardBackgroundColor="?attr/surface_nested"
            app:cardCornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@+id/scheduleCard"
            app:strokeColor="@color/glass_stroke"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/alwaysLockInLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:padding="10dp"
                    android:src="@drawable/smartphone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/text_primary" />

                <TextView
                    android:id="@+id/alwaysLockInTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Always Lock In"
                    android:textColor="?attr/text_primary"
                    android:textSize="15sp"
                    app:layout_constraintStart_toEndOf="@+id/alwaysLockInLogo"
                    app:layout_constraintTop_toTopOf="@+id/alwaysLockInLogo" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="sans-serif"
                    android:text="Start focus mode with essential apps only"
                    android:textColor="?attr/text_secondary"
                    android:textSize="11sp"
                    app:layout_constraintEnd_toStartOf="@+id/alwaysLockInSwitch"
                    app:layout_constraintStart_toStartOf="@+id/alwaysLockInTitle"
                    app:layout_constraintTop_toBottomOf="@+id/alwaysLockInTitle" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/alwaysLockInSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/alwaysLockInLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/alwaysLockInLogo"
                    app:thumbTint="?attr/switchThumb"
                    app:trackTint="?attr/switchTrack" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Custom App Blocking Card (BLACKLIST — blocks during focus) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/customAppBlockCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="?attr/surface_nested"
            app:cardCornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@+id/alwaysLockInCard"
            app:strokeColor="#4DFF5F5F"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/customAppBlockLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:backgroundTint="#33FF5F5F"
                    android:padding="10dp"
                    android:src="@drawable/smartphone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#FF5F5F" />

                <TextView
                    android:id="@+id/customAppBlockTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/custom_app_blocking"
                    android:textColor="?attr/text_primary"
                    android:textSize="15sp"
                    app:layout_constraintStart_toEndOf="@+id/customAppBlockLogo"
                    app:layout_constraintTop_toTopOf="@+id/customAppBlockLogo" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="sans-serif"
                    android:text="Blocked in all focus modes · Blacklist"
                    android:textColor="#FF5F5F"
                    android:textSize="11sp"
                    app:layout_constraintEnd_toStartOf="@+id/customAppBlockArrow"
                    app:layout_constraintStart_toStartOf="@+id/customAppBlockTitle"
                    app:layout_constraintTop_toBottomOf="@+id/customAppBlockTitle" />

                <ImageView
                    android:id="@+id/customAppBlockArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_right_arrow"
                    app:layout_constraintBottom_toBottomOf="@+id/customAppBlockLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/customAppBlockLogo"
                    app:tint="?attr/text_secondary" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Strict Focus Whitelist Card (WHITELIST — allowed during Strict Lock-In) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/strictWhitelistCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="?attr/surface_nested"
            app:cardCornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@+id/customAppBlockCard"
            app:strokeColor="#4D4CAF50"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/whitelistLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_circle"
                    android:backgroundTint="#334CAF50"
                    android:padding="10dp"
                    android:src="@drawable/ic_add"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#4CAF50" />

                <TextView
                    android:id="@+id/whitelistTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Strict Focus Whitelist"
                    android:textColor="?attr/text_primary"
                    android:textSize="15sp"
                    app:layout_constraintStart_toEndOf="@+id/whitelistLogo"
                    app:layout_constraintTop_toTopOf="@+id/whitelistLogo" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="sans-serif"
                    android:text="Apps allowed during Strict Lock-In · Whitelist"
                    android:textColor="#4CAF50"
                    android:textSize="11sp"
                    app:layout_constraintEnd_toStartOf="@+id/whitelistArrow"
                    app:layout_constraintStart_toStartOf="@+id/whitelistTitle"
                    app:layout_constraintTop_toBottomOf="@+id/whitelistTitle" />

                <ImageView
                    android:id="@+id/whitelistArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_right_arrow"
                    app:layout_constraintBottom_toBottomOf="@+id/whitelistLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/whitelistLogo"
                    app:tint="?attr/text_secondary" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            app:layout_constraintTop_toBottomOf="@+id/strictWhitelistCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


