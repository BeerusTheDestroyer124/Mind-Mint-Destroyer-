<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@drawable/rounded_bg"
    android:backgroundTint="?attr/surface_card"
    android:paddingBottom="32dp"
    tools:ignore="ContentDescription, HardcodedText, UseCompoundDrawables">

    <!-- 1. CLOSE BUTTON (Top Right) -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/glass_circle"
        android:padding="8dp"
        android:src="@drawable/x"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/text_secondary" />

    <!-- 2. HEADER & HERO (Floating Bag) -->
    <ImageView
        android:id="@+id/ivHeroIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/sack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <!-- Note: In production, replace src with your 3D Gem Bag drawable -->

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/poppins_semibold"
        android:text="Mint Crystals"
        android:textColor="?attr/text_primary"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivHeroIcon" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="48dp"
        android:gravity="center"
        android:text="Earn currency by staying focused and building consistent habits."
        android:textColor="?attr/text_tertiary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- 3. SCROLLABLE CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="24dp"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="500dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- SECTION A: BASE INCOME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.1"
                android:text="BASE INCOME"
                android:textColor="?attr/text_tertiary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Task Card (Emerald) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_glass"
                    android:backgroundTint="?attr/surface_nested"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:background="@drawable/glass_circle"
                        android:backgroundTint="?attr/browser_bg"
                        android:padding="8dp"
                        android:src="@drawable/list_todo"
                        app:tint="?attr/econ_emerald_text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="+2"
                        android:textColor="?attr/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PER TASK"
                        android:textColor="?attr/text_tertiary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Habit Card (Amber) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_glass"
                    android:backgroundTint="?attr/surface_nested"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">


                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:background="@drawable/glass_circle"
                        android:backgroundTint="?attr/econ_amber_bg"
                        android:padding="8dp"
                        android:src="@drawable/flame"
                        app:tint="?attr/econ_amber_text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="+5"
                        android:textColor="?attr/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PER HABIT"
                        android:textColor="?attr/text_tertiary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="FOCUS MULTIPLIER"
                android:textColor="?attr/text_tertiary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="?attr/surface_nested"
                android:background="@drawable/bg_surface_glass"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/glass_circle"
                        android:backgroundTint="?attr/brand_tint_bg"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="?attr/brand_pink" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Rewards scale with duration"
                        android:textColor="?attr/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- TIMELINE VISUALIZATION -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- The Line -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:background="?attr/econ_timeline_line"
                        app:layout_constraintBottom_toBottomOf="@+id/node30"
                        app:layout_constraintEnd_toEndOf="@+id/node180"
                        app:layout_constraintStart_toStartOf="@+id/node30"
                        app:layout_constraintTop_toTopOf="@+id/node30" />

                    <!-- Node 30m -->
                    <include
                        android:id="@+id/node30"
                        layout="@layout/item_timeline_node"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toStartOf="@id/node60"
                        app:layout_constraintHorizontal_chainStyle="spread_inside"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Node 60m -->
                    <include
                        android:id="@+id/node60"
                        layout="@layout/item_timeline_node"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toStartOf="@id/node90"
                        app:layout_constraintStart_toEndOf="@id/node30"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Node 90m -->
                    <include
                        android:id="@+id/node90"
                        layout="@layout/item_timeline_node"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toStartOf="@id/node120"
                        app:layout_constraintStart_toEndOf="@id/node60"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Node 120m -->
                    <include
                        android:id="@+id/node120"
                        layout="@layout/item_timeline_node"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toStartOf="@id/node150"
                        app:layout_constraintStart_toEndOf="@id/node90"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Node 150m -->
                    <include
                        android:id="@+id/node150"
                        layout="@layout/item_timeline_node"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toStartOf="@id/node180"
                        app:layout_constraintStart_toEndOf="@id/node120"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Node 180m -->
                    <include
                        android:id="@+id/node180"
                        layout="@layout/item_timeline_node"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/node150"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <!-- SECTION C: PENALTIES -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/bg_surface_glass"
                android:backgroundTint="?attr/status_error_bg"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/penaltyHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="@color/icon_critical" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:letterSpacing="0.1"
                        android:text="PENALTIES"
                        android:textColor="?attr/status_error_text"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/penaltyHeader">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stopped timer early"
                            android:textColor="?attr/status_error_text"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-3 Crystals"
                            android:layout_marginStart="5dp"
                            android:textColor="?attr/status_error_icon"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ignored 5 warnings"
                            android:textColor="?attr/status_error_text"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-2 Crystals"
                            android:layout_marginStart="5dp"
                            android:textColor="?attr/status_error_icon"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>