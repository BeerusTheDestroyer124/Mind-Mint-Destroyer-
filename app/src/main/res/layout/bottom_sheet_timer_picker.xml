<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/surface_card"
    android:orientation="vertical"
    android:padding="24dp"
    tools:ignore="HardcodedText,ContentDescription">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.5"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.1"
                android:text="LONG PRESS TO CHANGE"
                android:textAllCaps="true"
                android:textColor="?attr/text_tertiary"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="0.85"
                android:text="Set Timer"
                android:textColor="?attr/text_primary"
                android:textSize="30sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/timerPickerCloseBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/glass_circle"
            android:padding="10dp"
            android:src="@drawable/x"
            app:tint="?attr/text_secondary" />
    </LinearLayout>

    <!-- Large minute display -->
    <TextView
        android:id="@+id/timerPickerLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:text="25 min"
        android:textColor="?attr/text_primary"
        android:textSize="64sp" />

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/timerPickerSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:max="170"
        android:progress="15"
        android:thumbTint="@color/brainColor"
        android:progressTint="@color/brainColor" />

    <!-- Range labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.5"
            android:text="10 min"
            android:textColor="?attr/text_secondary"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.5"
            android:text="3 hrs"
            android:textColor="?attr/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Info text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_sheet_panel"
        android:lineSpacingMultiplier="1.3"
        android:padding="12dp"
        android:text="💡 Long-press the Start button anytime (when not running) to come back here and change your session duration."
        android:textColor="?attr/text_secondary"
        android:textSize="12sp" />

    <!-- Confirm button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/timerPickerConfirmBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/text_primary"
        android:fontFamily="@font/poppins_semibold"
        android:text="Set Timer"
        android:textColor="?attr/surface_card"
        android:textSize="15sp"
        app:cornerRadius="50dp" />

</LinearLayout>
