<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_habit_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="1dp"
    android:background="@drawable/bg_widget_card"
    android:orientation="vertical"
    android:padding="15dp">

    <!-- Top Section: Icon, Title, More -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_habit_icon"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:contentDescription="Habit icon"
            android:scaleType="fitCenter"
            tools:ignore="UseAppTint"
            tools:src="@drawable/flame" />

        <TextView
            android:id="@+id/widget_habit_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:text="Morning run"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/widget_middle_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <!-- Progress Info (Goal Mode Only) -->
        <LinearLayout
            android:id="@+id/widget_layout_progress_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_tv_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="4/10"
                android:textColor="@color/brand_pink"
                android:textSize="13sp"
                tools:ignore="HardcodedText" />

                <!-- Custom Progress Bar for Dynamic Tinting -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:id="@+id/widget_pb_bg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/shape_progress_bg"
                        android:scaleType="fitXY"/>

                    <ImageView
                        android:id="@+id/widget_pb_progress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/clip_progress_fg"
                        android:scaleType="fitXY"/>

                </FrameLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- Simple Status Text for Normal Habits (optional, kept small) -->
    <TextView
        android:id="@+id/widget_tv_mark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:text="CHECK IN"
        android:textAllCaps="true"
        android:textColor="@color/widget_text_tertiary"
        android:textSize="11sp"
        tools:ignore="HardcodedText" />

</LinearLayout>
