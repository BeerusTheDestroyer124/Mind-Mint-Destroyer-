<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_sheet_panel"
    android:paddingBottom="24dp"
    tools:ignore="ContentDescription, HardcodedText">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/iconHolder"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/bg_surface_glass"
            android:backgroundTint="?attr/glass_circle"
            android:padding="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivMainIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_secure"
                app:tint="#FF6B6B" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:text="Permission Title"
            android:textColor="?attr/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iconHolder" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:text="Description of why this permission is needed goes here."
            android:textColor="?attr/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2. STEPS CONTAINER -->
    <LinearLayout
        android:id="@+id/stepsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <!-- STEP 1 -->
        <include
            android:id="@+id/layoutStep1"
            layout="@layout/item_permission_step" />

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <!-- STEP 2 -->
        <include
            android:id="@+id/layoutStep2"
            layout="@layout/item_permission_step" />

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp" />
        <!-- STEP 3 -->
        <include
            android:id="@+id/layoutStep3"
            layout="@layout/item_permission_step" />

    </LinearLayout>

    <!-- 3. TRUST BADGE -->
    <LinearLayout
        android:id="@+id/trustBadge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/bg_surface_glass"
        android:backgroundTint="#1AFF6B6B"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/stepsContainer">

        <ImageView
            android:id="@+id/ivTrustIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_lock"
            app:tint="#FF6B6B" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTrustTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="PRIVACY GUARANTEE"
                android:textColor="#FF6B6B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTrustDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We do not collect personal data."
                android:textColor="#CCFF6B6B"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 4. BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/trustBadge">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_surface_glass"
            android:backgroundTint="?attr/surface_nested"
            android:text="Not Now"
            android:textAllCaps="false"
            android:textColor="?attr/text_secondary"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProceed"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="2"
            android:background="@drawable/bg_brand_gradient"
            android:text="Proceed to Settings"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>